<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>工作汇报</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            font-family: "PingFang SC","Microsoft YaHei",sans-serif;
            background:#f5f7fb;
            color:#333;
            line-height:1.6;
        }

        .container{
            max-width:1200px;
            margin:40px auto;
            padding:0 20px;
        }

        .header{
            background:#fff;
            border-radius:16px;
            padding:32px;
            margin-bottom:24px;
            box-shadow:0 4px 12px rgba(0,0,0,.05);
        }

        .header h1{
            font-size:32px;
            margin-bottom:10px;
        }

        .header p{
            color:#666;
        }

        .section{
            background:#fff;
            border-radius:16px;
            padding:28px;
            margin-bottom:24px;
            box-shadow:0 4px 12px rgba(0,0,0,.05);
        }

        .section-title{
            font-size:24px;
            margin-bottom:20px;
            padding-left:12px;
            border-left:5px solid #1677ff;
        }

        .grid{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:20px;
        }

        .card{
            background:#f8faff;
            border:1px solid #e6eefc;
            border-radius:12px;
            padding:20px;
        }

        .card h3{
            margin-bottom:12px;
            color:#1677ff;
        }

        .metric{
            font-size:30px;
            font-weight:bold;
            margin-top:10px;
        }

        .timeline-item{
            position:relative;
            padding-left:24px;
            margin-bottom:20px;
            border-left:2px solid #1677ff;
        }

        .timeline-item:last-child{
            margin-bottom:0;
        }

        .timeline-item::before{
            content:"";
            width:12px;
            height:12px;
            background:#1677ff;
            border-radius:50%;
            position:absolute;
            left:-7px;
            top:6px;
        }

        .timeline-date{
            color:#1677ff;
            font-weight:bold;
            margin-bottom:5px;
        }

        .plan-list{
            list-style:none;
        }

        .plan-list li{
            background:#f8faff;
            border-left:4px solid #1677ff;
            margin-bottom:12px;
            padding:14px 16px;
            border-radius:8px;
        }

        .footer{
            text-align:center;
            color:#999;
            padding:20px;
        }
    </style>
</head>

<body>

<div class="container">

    <!-- 页头 -->
    <div class="header">
        <h1>工作汇报</h1>
        <p>汇报周期：2026年6月 ｜ 汇报人：XXX</p>
    </div>

    <!-- 项目概览 -->
    <section class="section">
        <h2 class="section-title">项目概览</h2>

        <div class="grid">
            <div class="card">
                <h3>项目名称</h3>
                <p>智能工作台建设项目</p>
            </div>

            <div class="card">
                <h3>项目阶段</h3>
                <p>开发测试阶段</p>
            </div>

            <div class="card">
                <h3>整体进度</h3>
                <div class="metric">68%</div>
            </div>

            <div class="card">
                <h3>预计上线</h3>
                <p>2026-08-30</p>
            </div>
        </div>
    </section>

    <!-- 阶段性进展 -->
    <section class="section">
        <h2 class="section-title">阶段性进展</h2>

        <div class="timeline-item">
            <div class="timeline-date">第一阶段</div>
            <div>
                完成需求调研与方案设计，
                输出产品原型及技术架构方案。
            </div>
        </div>

        <div class="timeline-item">
            <div class="timeline-date">第二阶段</div>
            <div>
                完成核心功能开发，
                包括用户管理、权限管理和数据看板。
            </div>
        </div>

        <div class="timeline-item">
            <div class="timeline-date">第三阶段</div>
            <div>
                完成内部测试，
                修复主要缺陷并优化性能。
            </div>
        </div>
    </section>

    <!-- 后续计划 -->
    <section class="section">
        <h2 class="section-title">后续计划</h2>

        <ul class="plan-list">
            <li>
                <strong>6月下旬：</strong>
                完成剩余功能开发与联调测试。
            </li>

            <li>
                <strong>7月上旬：</strong>
                开展用户验收测试（UAT）。
            </li>

            <li>
                <strong>7月中旬：</strong>
                完成上线准备与培训材料编制。
            </li>

            <li>
                <strong>8月：</strong>
                正式发布并持续优化。
            </li>
        </ul>
    </section>

    <!-- 预留模块 -->
    <section class="section">
        <h2 class="section-title">待补充内容</h2>

        <div class="grid">
            <div class="card">
                <h3>关键成果</h3>
                <p>待填写...</p>
            </div>

            <div class="card">
                <h3>风险事项</h3>
                <p>待填写...</p>
            </div>

            <div class="card">
                <h3>资源需求</h3>
                <p>待填写...</p>
            </div>
        </div>
    </section>

    <div class="footer">
        Work Report Dashboard
    </div>

</div>

</body>
</html>
