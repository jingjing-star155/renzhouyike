  <script>
    let currentBannerPage = 0;
    const totalBannerPages = 3;

    function updateBanner() {
      const courses = document.getElementById('banner-courses');
      const dots = document.querySelectorAll('.pagination-dot');
      const prevBtn = document.getElementById('banner-prev');
      const nextBtn = document.getElementById('banner-next');
      
      courses.style.transform = `translateX(-${currentBannerPage * 100}%)`;
      
      dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === currentBannerPage);
      });
      
      prevBtn.disabled = currentBannerPage === 0;
      nextBtn.disabled = currentBannerPage === totalBannerPages - 1;
    }

    function bannerPrev() {
      if (currentBannerPage > 0) {
        currentBannerPage--;
        updateBanner();
      }
    }

    function bannerNext() {
      if (currentBannerPage < totalBannerPages - 1) {
        currentBannerPage++;
        updateBanner();
      }
    }

    function goToBannerPage(page) {
      currentBannerPage = page;
      updateBanner();
    }

    setInterval(() => {
      currentBannerPage = (currentBannerPage + 1) % totalBannerPages;
      updateBanner();
    }, 4000);

    let currentSidePage = 0;
    const totalSidePages = 3;

    function updateSideBanner() {
      const sideImages = document.getElementById('side-banner-images');
      const sideDots = document.querySelectorAll('.side-dot');
      
      sideImages.style.transform = `translateX(-${currentSidePage * 100}%)`;
      
      sideDots.forEach((dot, index) => {
        dot.classList.toggle('active', index === currentSidePage);
      });
    }

    function sidePrev() {
      if (currentSidePage > 0) {
        currentSidePage--;
        updateSideBanner();
      }
    }

    function sideNext() {
      if (currentSidePage < totalSidePages - 1) {
        currentSidePage++;
        updateSideBanner();
      }
    }

    function goToSidePage(page) {
      currentSidePage = page;
      updateSideBanner();
    }

    setInterval(() => {
      currentSidePage = (currentSidePage + 1) % totalSidePages;
      updateSideBanner();
    }, 4000);

    // 课程tab切换
    document.querySelectorAll('.course-tab-item').forEach(tab => {
      tab.addEventListener('click', function() {
        const tabId = this.getAttribute('data-tab');
        
        // 更新tab激活状态
        document.querySelectorAll('.course-tab-item').forEach(t => {
          t.classList.remove('active');
        });
        this.classList.add('active');
        
        // 更新内容显示
        document.querySelectorAll('.course-tab-content').forEach(content => {
          content.classList.remove('active');
        });
        document.getElementById('tab-' + tabId).classList.add('active');
      });
    });

    // 视频课程卡片跳转（仅tab-video内的卡片）
    document.querySelectorAll('#tab-video .video-card').forEach(card => {
      card.style.cursor = 'pointer';
      card.addEventListener('click', function() {
        window.location.href = 'series-courses-mobile.html';
      });
    });

    // 系列课程卡片跳转
    document.querySelectorAll('.series-card').forEach(card => {
      card.style.cursor = 'pointer';
      card.addEventListener('click', function() {
        window.location.href = 'series-courses-mobile.html';
      });
    });

    function openModal(courseName) {
      const modalOverlay = document.getElementById('modalOverlay');
      const modalMessage = document.getElementById('modalMessage');
      modalMessage.textContent = `您已成功报名《${courseName}》,请您按时出席此培训哦~~`;
      modalOverlay.classList.add('active');
    }

    function closeModal() {
      const modalOverlay = document.getElementById('modalOverlay');
      modalOverlay.classList.remove('active');
    }

    document.getElementById('modalOverlay').addEventListener('click', function(e) {
      if (e.target === this) {
        closeModal();
      }
    });

    document.addEventListener('DOMContentLoaded', function() {
      const offlineBtns = document.querySelectorAll('.offline-btn');
      offlineBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          const card = this.closest('.video-card');
          const courseTitle = card.querySelector('.video-title').textContent;
          openModal(courseTitle);
        });
      });

      const filterTabs = document.querySelectorAll('.filter-tab');
      filterTabs.forEach(tab => {
        tab.addEventListener('click', function() {
          filterTabs.forEach(t => t.classList.remove('active'));
          this.classList.add('active');
        });
      });

      const categoryTabs = document.querySelectorAll('.category-tab');
      categoryTabs.forEach(tab => {
        tab.addEventListener('click', function() {
          categoryTabs.forEach(t => t.classList.remove('active'));
          this.classList.add('active');
        });
      });

      const sortOptions = document.querySelectorAll('.sort-option');
      sortOptions.forEach(option => {
        option.addEventListener('click', function() {
          sortOptions.forEach(o => o.classList.remove('active'));
          this.classList.add('active');
          const arrow = this.querySelector('.sort-arrow');
          if (arrow) {
            arrow.textContent = arrow.textContent === '↑' ? '↓' : '↑';
          }
        });
      });
    });
  </script>
